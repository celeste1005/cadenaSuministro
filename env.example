# Copiar a packages/database/.env y apps/api/.env (misma DATABASE_URL).
DATABASE_URL="postgresql://usuario:password@localhost:5432/proyectocd?schema=public"

# API Nest (apps/api)
PORT=4000
JWT_SECRET=cambia-esto-en-produccion

# Redis opcional (colas Bull); si no tienes Redis, comenta BullModule en app.module o usa valores por defecto
REDIS_HOST=localhost
REDIS_PORT=6379

# Frontend (apps/web) — URL del API para tRPC en el navegador
NEXT_PUBLIC_API_URL=http://localhost:4000
