{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": ["JWT_SECRET", "DATABASE_URL", "REDIS_HOST", "REDIS_PORT", "PORT", "API_URL", "NEXT_PUBLIC_API_URL"]
    },
    "lint": {},
    "test": {},
    "db:generate": {
      "cache": false
    },
    "db:push": {
      "cache": false
    },
    "db:seed": {
      "cache": false
    }
  }
}
