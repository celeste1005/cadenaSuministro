model KpiCategory {
  id           Int             @id @default(autoincrement())
  code         String          @unique @db.VarChar(50)
  name         String          @db.VarChar(255)
  description  String?
  icon         String?         @db.VarChar(100)
  color        String?         @db.VarChar(50)
  displayOrder Int?            @default(0) @map("display_order")
  isActive     Boolean?        @default(true) @map("is_active")
  definitions  KpiDefinition[]

  @@map("kpi_categories")
}

model KpiDefinition {
  id               Int            @id @default(autoincrement())
  code             String         @unique @db.VarChar(50)
  categoryId       Int            @map("category_id")
  indicatorClass   IndicatorClass @default(PERFORMANCE) @map("indicator_class")
  name             String         @db.VarChar(255)
  description      String?
  objective        String?
  formula          String
  unit             String?        @db.VarChar(50)
  unitType         String?        @map("unit_type") @db.VarChar(20)
  direction        String?        @default("down") @db.VarChar(10)
  targetValue      Decimal?       @map("target_value") @db.Decimal(12, 4)
  minValue         Decimal?       @map("min_value") @db.Decimal(12, 4)
  maxValue         Decimal?       @map("max_value") @db.Decimal(12, 4)
  periodicity      String?        @default("monthly") @db.VarChar(20)
  responsibleRole  String?        @map("responsible_role") @db.VarChar(50)
  dataSource       String?        @map("data_source") @db.VarChar(255)
  calculationQuery String?        @map("calculation_query")
  isCustom         Boolean?       @default(false) @map("is_custom")
  isActive         Boolean?       @default(true) @map("is_active")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @default(now()) @updatedAt @map("updated_at")
  alerts           KpiAlert[]
  category         KpiCategory    @relation(fields: [categoryId], references: [id])
  values           KpiValue[]

  @@map("kpi_definitions")
}

model KpiValue {
  id                 String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  kpiId              Int               @map("kpi_id")
  companyId          String            @map("company_id") @db.Uuid
  branchId           String?           @map("branch_id") @db.Uuid
  periodDate         DateTime          @map("period_date") @db.Date
  actualValue        Decimal?          @map("actual_value") @db.Decimal(12, 4)
  targetValue        Decimal?          @map("target_value") @db.Decimal(12, 4)
  previousValue      Decimal?          @map("previous_value") @db.Decimal(12, 4)
  varianceAbsolute   Decimal           @map("variance_absolute") @db.Decimal(12, 4)
  variancePercentage Decimal?          @map("variance_percentage") @db.Decimal(12, 4)
  status             String?           @db.VarChar(20)
  dataSourceMetadata Json?             @map("data_source_metadata")
  calculatedBy       String?           @map("calculated_by") @db.Uuid
  calculatedAt       DateTime          @default(now()) @map("calculated_at")
  notes              String?
  alertHistory       KpiAlertHistory[]
  branch             Branch?           @relation(fields: [branchId], references: [id])
  calculator         User?             @relation(fields: [calculatedBy], references: [id])
  company            Company           @relation(fields: [companyId], references: [id])
  definition         KpiDefinition     @relation(fields: [kpiId], references: [id])

  @@unique([kpiId, companyId, periodDate, branchId])
  @@index([kpiId, companyId, periodDate, branchId], map: "idx_kpi_values_lookup")
  @@index([periodDate(sort: Desc)], map: "idx_kpi_values_period")
  @@map("kpi_values")
}

model KpiAlert {
  id                 String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  kpiId              Int               @map("kpi_id")
  thresholdType      String?           @map("threshold_type") @db.VarChar(20)
  thresholdValue     Decimal           @map("threshold_value") @db.Decimal(12, 4)
  comparisonOperator String?           @map("comparison_operator") @db.VarChar(5)
  severity           String?           @db.VarChar(20)
  isActive           Boolean?          @default(true) @map("is_active")
  createdAt          DateTime          @default(now()) @map("created_at")
  alertHistory       KpiAlertHistory[]
  definition         KpiDefinition     @relation(fields: [kpiId], references: [id])

  @@map("kpi_alerts")
}

model KpiAlertHistory {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  kpiValueId        String?   @map("kpi_value_id") @db.Uuid
  kpiAlertId        String?   @map("kpi_alert_id") @db.Uuid
  triggeredValue    Decimal?  @map("triggered_value") @db.Decimal(12, 4)
  notifiedTo        String?   @map("notified_to") @db.Uuid
  notifiedAt        DateTime  @default(now()) @map("notified_at")
  acknowledgedAt    DateTime? @map("acknowledged_at")
  acknowledgedBy    String?   @map("acknowledged_by") @db.Uuid
  acknowledgingUser User?     @relation("AcknowledgedBy", fields: [acknowledgedBy], references: [id])
  alert             KpiAlert? @relation(fields: [kpiAlertId], references: [id])
  kpiValue          KpiValue? @relation(fields: [kpiValueId], references: [id])
  notifiedUser      User?     @relation("NotifiedTo", fields: [notifiedTo], references: [id])

  @@map("kpi_alert_history")
}

model ReportTemplate {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId        String            @map("company_id") @db.Uuid
  name             String            @db.VarChar(255)
  description      String?
  templateHtml     String?           @map("template_html")
  templateStyles   String?           @map("template_styles")
  logoPosition     String?           @default("top-left") @map("logo_position") @db.VarChar(50)
  includeHeader    Boolean?          @default(true) @map("include_header")
  includeFooter    Boolean?          @default(true) @map("include_footer")
  pageSize         String?           @default("A4") @map("page_size") @db.VarChar(20)
  orientation      String?           @default("portrait") @db.VarChar(10)
  createdBy        String?           @map("created_by") @db.Uuid
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @default(now()) @updatedAt @map("updated_at")
  company          Company           @relation(fields: [companyId], references: [id])
  creator          User?             @relation(fields: [createdBy], references: [id])
  scheduledReports ScheduledReport[]

  @@map("report_templates")
}

model ScheduledReport {
  id               String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId        String          @map("company_id") @db.Uuid
  reportTemplateId String?         @map("report_template_id") @db.Uuid
  name             String          @db.VarChar(255)
  description      String?
  kpiIds           Int[]           @map("kpi_ids")
  filters          Json?           @default("{}")
  recipientEmails  String[]        @map("recipient_emails")
  scheduleCron     String          @map("schedule_cron") @db.VarChar(100)
  timezone         String?         @default("America/Bogota") @db.VarChar(50)
  format           String?         @default("pdf") @db.VarChar(20)
  includeCharts    Boolean?        @default(true) @map("include_charts")
  includeTables    Boolean?        @default(true) @map("include_tables")
  isActive         Boolean?        @default(true) @map("is_active")
  lastGeneratedAt  DateTime?       @map("last_generated_at")
  lastError        String?         @map("last_error")
  createdBy        String?         @map("created_by") @db.Uuid
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @default(now()) @updatedAt @map("updated_at")
  history          ReportHistory[]
  company          Company         @relation(fields: [companyId], references: [id])
  creator          User?           @relation(fields: [createdBy], references: [id])
  template         ReportTemplate? @relation(fields: [reportTemplateId], references: [id])

  @@map("scheduled_reports")
}

model ReportHistory {
  id                String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  scheduledReportId String?          @map("scheduled_report_id") @db.Uuid
  generatedAt       DateTime         @default(now()) @map("generated_at")
  fileUrl           String?          @map("file_url")
  fileSizeBytes     Int?             @map("file_size_bytes")
  recipientCount    Int?             @map("recipient_count")
  status            String?          @db.VarChar(20)
  errorMessage      String?          @map("error_message")
  report            ScheduledReport? @relation(fields: [scheduledReportId], references: [id])

  @@map("report_history")
}

enum IndicatorClass {
  UTILIZATION
  PERFORMANCE
  PRODUCTIVITY
}
