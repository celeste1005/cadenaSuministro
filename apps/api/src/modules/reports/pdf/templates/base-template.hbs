<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>{{title}}</title>
  <style>
    {{reportCss}}
  </style>
</head>
<body>
  <div class="page">
    <div class="header">
      {{#if companyInfo.logo}}
        <img class="logo" src="{{companyInfo.logo}}" alt="Logo">
      {{/if}}
      <div class="company-name">{{companyInfo.name}}</div>
      <div class="report-title">{{title}}</div>
      {{#if subtitle}}
        <div class="report-subtitle">{{subtitle}}</div>
      {{/if}}
    </div>

    <div class="metadata-bar">
      <span><strong>Período:</strong> {{periodLabel}}</span>
      <span><strong>Generado:</strong> {{generatedAt}}</span>
      <span><strong>Por:</strong> {{generatedBy}}</span>
    </div>

    {{#if summary}}
    <div class="summary-cards">
      {{#if summary.totalKpis}}
        <div class="card blue">
          <div class="card-title">Total KPIs</div>
          <div class="card-value">{{summary.totalKpis}}</div>
          <div class="card-subtitle">Indicadores monitoreados</div>
        </div>
      {{/if}}
      {{#if summary.onTarget}}
        <div class="card green">
          <div class="card-title">En Meta</div>
          <div class="card-value">{{summary.onTarget}}</div>
          <div class="card-subtitle">({{summary.onTargetPercent}}%)</div>
        </div>
      {{/if}}
      {{#if summary.warning}}
        <div class="card orange">
          <div class="card-title">En Alerta</div>
          <div class="card-value">{{summary.warning}}</div>
          <div class="card-subtitle">Requieren atención</div>
        </div>
      {{/if}}
      {{#if summary.critical}}
        <div class="card pink">
          <div class="card-title">Críticos</div>
          <div class="card-value">{{summary.critical}}</div>
          <div class="card-subtitle">Fuera de rango</div>
        </div>
      {{/if}}
    </div>
    {{/if}}

    {{{content}}}
  </div>
</body>
</html>
