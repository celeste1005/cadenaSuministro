<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Reporte Completo de KPIs - {{periodLabel}}</title>
  <style>
    {{reportCss}}
  </style>
</head>
<body>
  <div class="page">
    <div class="header">
      {{#if companyInfo.logo}}
        <img class="logo" src="{{companyInfo.logo}}" alt="Logo">
      {{/if}}
      <div class="company-name">{{companyInfo.name}}</div>
      <div class="report-title">Reporte Integral de Indicadores Logísticos</div>
      <div class="report-subtitle">28 KPIs de gestión - Clasificados por categoría</div>
    </div>

    <div class="metadata-bar">
      <span><strong>Período:</strong> {{periodLabel}}</span>
      <span><strong>Generado:</strong> {{generatedAt}}</span>
      <span><strong>Por:</strong> {{generatedBy}}</span>
      <span><strong>Total KPIs:</strong> {{summary.totalKpis}}</span>
    </div>

    <div class="summary-cards">
      <div class="card green">
        <div class="card-title">En Meta</div>
        <div class="card-value">{{summary.onTarget}}</div>
        <div class="card-subtitle">{{summary.onTargetPercent}}% del total</div>
      </div>
      <div class="card orange">
        <div class="card-title">En Alerta</div>
        <div class="card-value">{{summary.warning}}</div>
        <div class="card-subtitle">Requieren atención</div>
      </div>
      <div class="card pink">
        <div class="card-title">Críticos</div>
        <div class="card-value">{{summary.critical}}</div>
        <div class="card-subtitle">Fuera de rango</div>
      </div>
      <div class="card purple">
        <div class="card-title">Cumplimiento Promedio</div>
        <div class="card-value">{{summary.averageCompliance}}%</div>
        <div class="card-subtitle">General</div>
      </div>
    </div>

    {{#if hasAlerts}}
    <div class="insight-box {{alertLevel}}">
      <div class="insight-title">
        {{#if (eq alertLevel 'danger')}}⚠️ Atención requerida{{/if}}
        {{#if (eq alertLevel 'warning')}}⚡ Alertas activas{{/if}}
        {{#if (eq alertLevel 'success')}}✅ Sin novedades críticas{{/if}}
      </div>
      <p>{{alertMessage}}</p>
    </div>
    {{/if}}

    <div class="toc">
      <h3 style="margin-bottom: 8px; font-size: 11pt;">Contenido</h3>
      {{#each categories}}
        <div class="toc-item">
          <span class="toc-num">{{@index_plus_1}}.</span>
          <span>{{category.name}}</span>
          <span class="toc-dots"></span>
          <span class="toc-page">{{items.length}} indicadores</span>
        </div>
      {{/each}}
    </div>

    {{#each categories}}
    <div class="page-break"></div>
    <div class="category-header">
      <span class="color-dot" style="background: {{category.color}};"></span>
      <span class="cat-name">{{category.name}}</span>
      <span class="cat-count">{{items.length}} indicadores</span>
    </div>

    {{#if categoryChart}}
    <div class="chart-container">
      <img class="chart-image" src="{{categoryChart}}" alt="Gráfico {{category.name}}">
    </div>
    {{/if}}

    <div class="kpi-grid">
      {{#each items}}
      <div class="kpi-card">
        <div class="kpi-header">
          <span class="kpi-code">{{code}}</span>
          <span class="kpi-status {{status}}">{{statusLabel}}</span>
        </div>
        <div class="kpi-name">{{name}}</div>
        <div class="kpi-value-row">
          <span class="kpi-value">{{formatKpiValue value unit}}</span>
          {{#if target}}
            <span class="kpi-target">Meta: {{formatKpiValue target unit}}</span>
          {{/if}}
        </div>
        {{#if variancePercentage}}
        <div style="font-size: 7pt; margin-top: 4px; color: #64748b;">
          Variación: {{variancePercentage}}% vs período anterior
        </div>
        {{/if}}
        <div class="kpi-formula">{{formula}}</div>
      </div>
      {{/each}}
    </div>
    {{/each}}

    <div class="footer">
      <p>Este reporte es generado automáticamente por SCILIP - Sistema de Control de Indicadores Logísticos</p>
      <p>© {{year}} {{companyInfo.name}} - Reporte institucional de gestión</p>
    </div>
  </div>
</body>
</html>
